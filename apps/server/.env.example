# Copy to apps/server/.env (loaded by your process manager) or set in the shell.

# Port + host the server listens on.
PORT=4000
HOST=localhost

# Absolute origin the renderer's headless Chromium uses to fetch /storage media.
# Must be reachable from the render machine. Defaults to http://HOST:PORT.
SERVER_ORIGIN=http://localhost:4000

# Draft (edge-tts) Tamil voice. Draft/preview only — never shipped audio.
TA_VOICE=ta-IN-PallaviNeural

# Draft voice worker tuning.
WORKER_POLL_MS=4000
WORKER_STALE_MS=2400000

# ---- Security / ops (all opt-in; unset = open, fine for localhost/LAN) ------
# Require this token on /api/* (except /api/health) via Authorization: Bearer
# <token> or x-api-token. Set before exposing the server publicly.
# API_TOKEN=
# Comma-separated allowed CORS origins (unset = allow any, for dev).
# CORS_ORIGIN=https://reels.example.com
# Prune approved/rejected jobs + their media older than N days (0 = off).
# RETENTION_DAYS=14

# ---- Queue backend --------------------------------------------------------
# "local" (filesystem, default) or "gdrive" (Google Drive API).
QUEUE_BACKEND=local

# local backend: override the on-disk queue root (e.g. a Drive-for-Desktop
# synced folder for the throwaway local Drive test).
# QUEUE_DIR=G:\My Drive\reel-queue

# gdrive backend (see docs/google-drive-setup.md): OAuth user refresh token +
# the id of the queue root folder in that user's My Drive.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# DRIVE_ROOT_FOLDER_ID=
# DRIVE_POLL_MS=8000
