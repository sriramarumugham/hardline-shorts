{
  "name": "news-reel-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Web-based factory that turns Tamil news articles into vertical (1080x1920) reels at scale, operated by non-developers. See blueprint.md.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace @factory/server run dev",
    "dev:web": "npm --workspace @factory/web run dev",
    "build:web": "npm --workspace @factory/web run build",
    "worker:draft": "npm --workspace @factory/server run worker:draft"
  },
  "devDependencies": {
    "concurrently": "8.2.2"
  }
}
